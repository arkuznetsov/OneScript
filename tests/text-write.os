	ЗаписьТекста.Записать("Привет");
	ЗаписьТекста.Закрыть();

	// Тогда
	ЧтениеТекста = Новый ЧтениеТекста(Поток, "windows-1251");
	Поток.Перейти(0, ПозицияВПотоке.Начало);

	Попытка
		юТест.ПроверитьРавенство(ЧтениеТекста.ПрочитатьСтроку(), "Привет");
		юТест.ПроверитьРавенство(Поток.Размер(), 6);
	Исключение
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

