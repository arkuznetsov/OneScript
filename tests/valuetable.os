	юТест.ПроверитьРавенство(КодСимвола(ТЗ[1].Тест,1), 69, "latin");
	юТест.ПроверитьРавенство(КодСимвола(ТЗ[2].Тест,1), 65317, "full-width");
	юТест.ПроверитьРавенство(КодСимвола(ТЗ[3].Тест,1), 917, "greek");
